class Solution(object):
    def isPalindrome(self, x):
        """
        :type x: int
        :rtype: bool
        """
        a=[]
        x=str(x)
        for i in range(len(x)-1,-1,-1):
            a+=x[i]
        b="".join(a)
        if x==b:
            return True 
